{% apply spaceless %}

{#
  Parameters:
    - "id" (string) (default: random): page summary id
    - "title" (string) (default: ''): page summary title
    - "description" (string) (default: ''): page summary description
    - "icon" (object) (default: ''): icon for the title; follows the ECL Icon structure
    - "extra_classes" (string) (default: '')
    - "extra_attributes" (array) (default: []) Extra attributes
      - "name" (string) Attribute name, eg. 'data-test'
      - "value" (string) Attribute value, eg: 'data-test-1'
#}

{# Internal properties #}

{% set _css_class = 'ecl-page-summary' %}
{% set _extra_attributes = '' %}
{% set _id = id|default('ecl-page-summary-' ~ random()) %}
{% set _title = title|default('') %}
{% set _description = description|default('') %}
{% set _icon = icon|default({}) %}

{# Internal logic - Process properties #}

{% if extra_classes is defined and extra_classes is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ extra_classes %}
{% endif %}

{% if extra_attributes is defined and extra_attributes is not empty and extra_attributes is iterable %}
  {% for attr in extra_attributes %}
    {% if attr.value is defined %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') ~ '="' ~ attr.value|e('html_attr') ~ '"' %}
    {% else %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') %}
    {% endif %}
  {% endfor %}
{% endif %}

{# Print the result #}

<section
  class="{{ _css_class }}"
  id="{{ _id }}"
  aria-labelledby="{{ _id }}-title"
  {{ _extra_attributes|raw }}
>
  {% if _title is not empty or _icon is not empty %}
    <div class="ecl-page-summary__header">
      {# Icon #}
      {% if _icon is not empty %}
        {% include '@ecl/icon/icon.html.twig' with {
          icon: _icon,
          extra_classes: "ecl-page-summary__icon",
        } only %}
      {% endif %}

      {# Title #}
      {% if _title is not empty %}
        <h2 class="ecl-page-summary__title" id="{{ _id }}-title">{{ _title }}</h2>
      {% endif %}
    </div>
  {% endif %}

  {% if _description is not empty %}
    {# Description #}
    <div class="ecl-page-summary__description">
      {{- _description -}}
    </div>
  {% endif %}
  </section>

{% endapply %}
