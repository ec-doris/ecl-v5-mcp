{% apply spaceless %}

{#
  Parameters:
    - "labels" (array) (default: []): Array of ECL Labels
    - "labels_aria" (string) (default: ''): Aria label for the labels area
    - "primary_meta" (array of string) (default: []): Primary meta of the content block
    - "title" (associative array OR string) (default: {}): Title of the content block, following ECL Link structure
    - "description" (string) (default: ''): Description of the content block
    - "secondary_meta" (array) (default: []): format: [
        {
          "label" (string) (default: ''): Label of secondary meta item
          "icon" (array) (default: {}) Icon of the secondary meta, following ECL Icon structure
        },
        ...
      ]
    - "secondary_meta_direction" (string) (default: 'vertical'): Display direction of the meta
    - "links" (array) (default: []): Array or multi array of ECL Links
    - "lists" (array) (default: []): Array of ECL Description list
    - "extra_classes" (string) (default: '')
    - "extra_attributes" (array) (default: []): format: [
        {
          "name" (string) (default: ''),
          "value" (optional) (string)
        ...
      ],
#}

{# Internal properties #}

{% set _labels = labels|default([]) %}
{% set _labels_aria = labels_aria|default('') %}
{% set _primary_meta = primary_meta|default([]) %}
{% set _title = title|default({}) %}
{% set _description = description|default('') %}
{% set _secondary_meta = secondary_meta|default([]) %}
{% set _secondary_meta_direction = secondary_meta_direction|default('vertical') %}
{% set _links = links|default([]) %}
{% set _lists = lists|default([]) %}
{% set _css_class = 'ecl-content-block' %}
{% set _extra_attributes = '' %}

{# Internal logic - Process properties #}

{% if extra_classes is defined and extra_classes is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ extra_classes %}
{% endif %}

{% if extra_attributes is defined and extra_attributes is not empty and extra_attributes is iterable %}
  {% for attr in extra_attributes %}
    {% if attr.value is defined %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') ~ '="' ~ attr.value|e('html_attr') ~ '"' %}
    {% else %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') %}
    {% endif %}
  {% endfor %}
{% endif %}

{# Print the result #}

<div
  class="{{ _css_class }}"
  {{ _extra_attributes|raw }}
  data-ecl-auto-init="ContentBlock"
  data-ecl-content-block
>
  {# Label #}
  {% if _labels is defined and _labels is not empty and _labels is iterable %}
    {% set _tag_labels_list = _labels|length == 1 ? 'div' : 'ul' %}
    {% set _tag_labels_item = _labels|length == 1 ? 'div' : 'li' %}
    <{{ _tag_labels_list }} class="ecl-content-block__label-container"
      {%- if _labels_aria is not empty -%}
        aria-label="{{ _labels_aria }}"
      {%- endif -%}
    >
      {% for _label in _labels %}
        <{{ _tag_labels_item }} class="ecl-content-block__label-item">
          {% include '@ecl/label/label.html.twig' with _label only %}
        </{{ _tag_labels_item }}>
      {% endfor %}
    </{{ _tag_labels_list }}>
  {% endif %}

  {# Primary meta #}
  {% if _primary_meta is not empty and _primary_meta is iterable %}
    {% set _tag_meta_list = _primary_meta|length == 1 ? 'div' : 'ul' %}
    {% set _tag_meta_item = _primary_meta|length == 1 ? 'div' : 'li' %}
    <{{ _tag_meta_list }} class="ecl-content-block__primary-meta-container">
      {% for _meta in _primary_meta %}
        <{{ _tag_meta_item }} class="ecl-content-block__primary-meta-item">
          {{- _meta -}}
        </{{ _tag_meta_item }}>
      {% endfor %}
    </{{ _tag_meta_list }}>
  {% endif %}

  {# Title #}
  {% if _title is not empty %}
    <div class="ecl-content-block__title">
    {%- if _title.link is defined -%}
      {% include '@ecl/link/link.html.twig' with _title|merge({
          extra_attributes: _title.extra_attributes|default([])|merge([{ name: 'data-ecl-title-link' }]),
      }) only %}
    {%- else -%}
      {{- _title -}}
    {%- endif -%}
    </div>
  {% endif %}

  {# Description #}
  {% if _description is not empty %}
    <div class="ecl-content-block__description">{{ _description }}</div>
  {% endif %}

  {# Secondary meta #}
  {% if _secondary_meta is not empty and _secondary_meta is iterable %}
    {% set _secondary_meta_class = "ecl-content-block__secondary-meta-container" %}
    {% if _secondary_meta_direction == "horizontal" %}
      {% set _secondary_meta_class = _secondary_meta_class ~ " ecl-content-block__secondary-meta-container--horizontal" %}
    {% endif %}
    {% set _tag_secondary_list = _secondary_meta|length == 1 ? 'div' : 'ul' %}
    {% set _tag_secondary_item = _secondary_meta|length == 1 ? 'div' : 'li' %}
    <{{ _tag_secondary_list }} class="{{ _secondary_meta_class }}">
      {% for _meta in _secondary_meta %}
        <{{ _tag_secondary_item }} class="ecl-content-block__secondary-meta-item">
          {% if _meta.icon is not empty %}
            {% include '@ecl/icon/icon.html.twig' with {
              icon: _meta.icon|merge({
                size: 's',
              }),
              extra_classes: 'ecl-content-block__secondary-meta-icon'
            } only %}
          {% endif %}
          <span class="ecl-content-block__secondary-meta-label">{{ _meta.label }}</span>
        </{{ _tag_secondary_item }}>
      {% endfor %}
    </{{ _tag_secondary_list }}>
  {% endif %}

  {# List #}
  {% if _lists is defined and _lists is not empty and _lists is iterable %}
    <div class="ecl-content-block__list-container">
    {% for _list in _lists %}
      {% set _list_classes = 'ecl-content-block__list' %}
      {% if _list.extra_classes is defined and _list.extra_classes is not empty %}
        {% set _list_classes = _list_classes ~ ' ' ~ _list.extra_classes %}
      {% endif %}
      {% include '@ecl/description-list/description-list.html.twig' with _list|merge({
        extra_classes: _list_classes,
      }) only %}
    {% endfor %}
    </div>
  {% endif %}

  {# Links #}
  {% if _links is not empty and _links is iterable %}
    <div class="ecl-content-block__link-container">
    {% if _links[0][0] is defined %}
      {% for _link_section in _links %}
      {% set _tag_link_list = _link_section|length == 1 ? 'div' : 'ul' %}
      {% set _tag_link_item = _link_section|length == 1 ? 'div' : 'li' %}
      <{{ _tag_link_list }} class="ecl-content-block__link-list">
      {% for _link in _link_section %}
        <{{ _tag_link_item }} class="ecl-content-block__link-item">
        {%- if _link.link is defined -%}
          {% include '@ecl/link/link.html.twig' with {
            link: _link.link|merge({
              type: 'standalone',
            }),
            extra_attributes: _link.extra_attributes|default([]),
            icon: _link.icon|default({})
          } only %}
        {%- else -%}
          {{- _link -}}
        {%- endif -%}
        </{{ _tag_link_item }}>
      {% endfor %}
      </{{ _tag_link_list }}>
      {% endfor %}
    {% else %}
      {% set _tag_link_list = _links|length == 1 ? 'div' : 'ul' %}
      {% set _tag_link_item = _links|length == 1 ? 'div' : 'li' %}
      <{{ _tag_link_list }} class="ecl-content-block__link-list">
      {% for _link in _links %}
        <{{ _tag_link_item }} class="ecl-content-block__link-item">
        {%- if _link.link is defined -%}
          {% include '@ecl/link/link.html.twig' with {
            link: _link.link|merge({
              type: 'standalone',
            }),
            extra_attributes: _link.extra_attributes|default([]),
            icon: _link.icon|default({})
          } only %}
        {%- else -%}
          {{- _link -}}
        {%- endif -%}
        </{{ _tag_link_item }}>
      {% endfor %}
      </{{ _tag_link_list }}>
      {% endif %}
    </div>
  {% endif %}
</div>

{% endapply %}
