{% apply spaceless %}

{#
  Parameters:
  - "with_background" (boolean) (default: false) Display with a colored background
  - "full_width" (boolean) (default: false) Full width display with background (inside the grid)
  - "border" (boolean) (default: false) Display with a border around each item
  - "counter_color" (boolean) (default: true) Apply color to the counter value
  - "sources_label" (string) (default: '') Label displayed before the sources list
  - "items" (array) (default: []):
    - "category" (string) (default: '') Category label above the value
    - "icon" (object) (default: {}) Object of type ECL icon
    - "prefix" (string) (default: '') Text displayed before the value
    - "prefix_label" (string) (default: '') Screen reader text for the prefix
    - "value" (string) (default: '') The main numeric value to display
    - "suffix" (string) (default: '') Text displayed after the value
    - "suffix_label" (string) (default: '') Screen reader text for the suffix
    - "description" (string) (default: '') Description below the value
  - "sources" (array) (default: []) Array of source references (ECL link objects or plain strings)
    - "link" (object) ECL link object:
      - "label" (string) (default: '') Link label
      - "path" (string) (default: '') Link URL
      or
    - "name" (string) (default: '') Plain text source
  - "extra_classes" (string) (default: '') Extra classes (space separated)
  - "extra_attributes" (array) (default: []): format: [
        {
          "name" (string) (default: ''),
          "value" (string) (default: '')
        },
        ...
      ],
#}

{# Parameters #}

{% set _css_class = 'ecl-animated-numbers' %}
{% set _extra_attributes = '' %}
{% set _counter_color = counter_color ?? true %}
{% set _border = border|default(false) %}
{% set _sources_label = sources_label|default('') %}
{% set _with_background = with_background|default(false) %}
{% set _full_width = full_width|default(false) %}
{% set _items = items|default([]) %}
{% set _extra_classes = extra_classes|default('') %}
{% set _sources = sources|default([]) %}

{# Internal logic - Process properties #}

{% if _border %}
  {% set _css_class = _css_class ~ ' ecl-animated-numbers--border' %}
{% endif %}

{% if _with_background or _full_width %}
  {% set _css_class = _css_class ~ ' ecl-animated-numbers--with-background' %}
  {% set _counter_color = false %}
{% endif %}

{% if _full_width %}
  {% set _css_class = _css_class ~ ' ecl-animated-numbers--full-width' %}
{% endif %}

{% if _counter_color %}
  {% set _css_class = _css_class ~ ' ecl-animated-numbers--counter-color' %}
{% endif %}

{% if extra_classes is defined and extra_classes is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ extra_classes %}
{% endif %}

{% if extra_attributes is defined and extra_attributes is not empty and extra_attributes is iterable %}
  {% for attr in extra_attributes %}
    {% if attr.value is defined %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') ~ '="' ~ attr.value|e('html_attr') ~ '"' %}
    {% else %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') %}
    {% endif %}
  {% endfor %}
{% endif %}

<div
  class="{{ _css_class }}"
  {{ _extra_attributes|raw }}
  data-ecl-animated-numbers
  data-ecl-auto-init="AnimatedNumbers"
>
{% if (_items is not empty and _items is iterable) or (_sources is not empty and _sources is iterable) %}
  {% if _full_width %}
    <div class="ecl-container">
  {% endif %}
      <article class="ecl-animated-numbers__wrapper">
      {% if _items is not empty and _items is iterable %}
        <ul class="ecl-animated-numbers__items">
        {% for item in _items %}
          {% set _item_class = 'ecl-animated-number' %}
          <li class="{{ _item_class }}">
            <div class="ecl-animated-number__header">
            {% if item.category is defined and item.category is not empty %}
              <div class="ecl-animated-number__category">
                {{- item.category -}}
              </div>
            {% endif %}
            {% if item.icon is defined and item.icon is not empty %}
              {% include '@ecl/icon/icon.html.twig' with {
                icon: item.icon|merge({
                  size: 'xl',
                  color: _counter_color ? 'primary' : null
                }),
                extra_classes: 'ecl-animated-number__icon',
              } only %}
            {% endif %}
            </div>
            <div class="ecl-animated-number__content">
              <span class="ecl-animated-number__number">
              {% if item.prefix is defined and item.prefix is not empty %}
                <span class="ecl-animated-number__prefix">
                  {%- if item.prefix_label is defined and item.prefix_label is not empty -%}
                    <span class="ecl-animated-number__prefix-label">{{- item.prefix_label -}}</span>
                  {%- endif -%}
                  {{- item.prefix -}}
                </span>
              {% endif %}
              {% if item.value is defined and item.value is not empty %}
                <span
                  class="ecl-animated-number__value"
                  data-ecl-animated-numbers-value
                >
                  {{- item.value -}}
              </span>
              {% endif %}
              {% if item.suffix is defined and item.suffix is not empty %}
                <span class="ecl-animated-number__suffix">
                  {%- if item.suffix_label is defined and item.suffix_label is not empty -%}
                    <span class="ecl-animated-number__suffix-label">{{- item.suffix_label -}}</span>
                  {%- endif -%}
                  {{- item.suffix -}}
                </span>
              {% endif %}
              </span>
              {% if item.description is defined and item.description is not empty %}
                <span class="ecl-animated-number__description">
                  {{- item.description -}}
                </span>
              {% endif %}
            </div>
          </li>
        {% endfor %}
        </ul>
      {% endif %}
      {% if _sources is not empty and _sources is iterable %}
        <footer class="ecl-animated-numbers__sources">
          {% if _sources_label is not empty %}
          <span class="ecl-animated-numbers__sources-label">
            {{- _sources_label -}}
          </span>
          {% endif %}
      {% if _sources|length == 1 %}
        {% set source = _sources|first %}

        {% if source.link is defined and source.link is not empty %}
          {% include '@ecl/link/link.html.twig' with {
            link: source.link|merge({
              inverted: _with_background,
            }),
            extra_classes: 'ecl-animated-numbers__source'
          } only %}
        {% else %}
          <span class="ecl-animated-numbers__source">
            {{ source.name }}
          </span>
        {% endif %}

        {% elseif _sources|length > 1 %}
          <ul class="ecl-animated-numbers__sources-list">
            {% for source in _sources %}
              <li class="ecl-animated-numbers__sources-item">
                {% if source.link is defined and source.link is not empty %}
                  {% include '@ecl/link/link.html.twig' with {
                    link: source.link|merge({
                      inverted: _with_background,
                    }),
                    extra_classes: 'ecl-animated-numbers__source'
                  } only %}
                {% else %}
                  <span class="ecl-animated-numbers__source">
                    {{ source.name }}
                  </span>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
        </footer>
      {% endif %}
      </article>
  {% if _full_width %}
    </div>
  {% endif %}
{% endif %}
</div>

{% endapply %}
