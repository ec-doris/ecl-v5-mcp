{% apply spaceless %}

{#
  Parameters:
    - "color_mode" (string) (default: '') name of the color mode
    - "id" (string) (default: random): highlight box id
    - "title" (string) (default: ''): highlight box title
    - "description" (string) (default: ''): highlight box description
    - "icon" (object) (default: ''): icon for the title; follows the ECL Icon structure
    - "link" (object) (default: {}): optional link; follows the ECL Link structure
    - "extra_classes" (string) (default: '')
    - "extra_attributes" (optional) (array) (default: [])
      - "name" (string) Attribute name, eg. 'data-test'
      - "value" (optional) (string) Attribute value, eg: 'data-test-1'
#}

{# Internal properties #}

{% set _css_class = 'ecl-highlight-box' %}
{% set _extra_attributes = '' %}
{% set _color_mode = color_mode|default('') %}
{% set _id = id|default('ecl-highlight-box-' ~ random()) %}
{% set _title = title|default('') %}
{% set _description = description|default('') %}
{% set _icon = icon|default({}) %}
{% set _link = link|default({}) %}

{# Internal logic - Process properties #}

{% if _color_mode is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ 'ecl-color-mode--' ~ _color_mode %}
{% endif %}

{% if extra_classes is defined and extra_classes is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ extra_classes %}
{% endif %}

{% if extra_attributes is defined and extra_attributes is not empty and extra_attributes is iterable %}
  {% for attr in extra_attributes %}
    {% if attr.value is defined %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') ~ '="' ~ attr.value|e('html_attr') ~ '"' %}
    {% else %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') %}
    {% endif %}
  {% endfor %}
{% endif %}

{# Print the result #}

<article
  class="{{ _css_class }}"
  id="{{ _id }}"
  aria-labelledby="{{ _id }}-title"
  {{ _extra_attributes|raw }}
>
  {% if _title is not empty or _icon is not empty %}
    <header class="ecl-highlight-box__header">
      {# Icon #}
      {% if _icon is not empty %}
        <div class="ecl-highlight-box__icon-wrapper">
          {% include '@ecl/icon/icon.html.twig' with {
            icon: _icon,
            extra_classes: "ecl-highlight-box__icon",
          } only %}
        </div>
      {% endif %}

      {# Title #}
      {% if _title is not empty %}
        <div class="ecl-highlight-box__title" id="{{ _id }}-title">{{ _title }}</div>
      {% endif %}
    </header>
  {% endif %}

  {% if _description is not empty or _link is not empty %}
    <div class="ecl-highlight-box__body">
      {% if _description is not empty %}
        {# Description #}
        <div class="ecl-highlight-box__description">
          {{- _description -}}
        </div>
      {% endif %}

      {% if _link is not empty %}
        {# Link #}
        {% include '@ecl/link/link.html.twig' with _link|merge({
          link: _link.link|merge({
            type: 'secondary-neutral',
          }),
          extra_classes: "ecl-highlight-box__link",
        }) only %}
      {% endif %}
    </div>
  {% endif %}
</article>

{% endapply %}
