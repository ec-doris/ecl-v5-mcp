{% apply spaceless %}

{#
  Parameters:
    - "color_mode" (string) (default: '') Name of the color mode
    - "items" (array) (default: []): format: [
      {
        "toggle" (object): Toggle button for the accordion item, format: {
          "label" (string) (default: '') Label of the toggle button
          "extra_classes" (string) (default: '') Extra classes for the toggle button
        },
        "content" (string) (default: '') Content inside the accordion item
      },
      ...
    ]
    - "sidebar" (boolean) (default: false) If true, the accordion will be styled for use in a sidebar
    - "icon" (array) OR (object) (default: []) Two icons in an array that will be toggled (open/close)
    - "name" (string) (default: '') Optional name attribute to link multiple accordion items
    - "extra_classes" (string) (default: '') Extra classes (space separated)
    - "extra_attributes" (array) (default: []): format: [
        {
          "name" (string) (default: ''),
          "value" (string) (default: '')
        },
        ...
      ],
#}

{# Internal properties #}

{% set _color_mode = color_mode|default('') %}
{% set _css_class = 'ecl-accordion' %}
{% set _extra_attributes = '' %}
{% set _items = items|default([]) %}
{% set _name = name|default('') %}
{% set _icons = icon is iterable and icon|keys is not empty ? icon : [icon] %}
{% set _sidebar = sidebar|default(false) %}

{% if _icons|length == 1 and _icons[0].name == 'plus' %}
  {% set _icons = _icons|merge([{'name': 'minus', 'path': _icons[0].path}]) %}
{% endif %}

{# Internal logic - Process properties #}

{% if _color_mode is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ 'ecl-color-mode--' ~ _color_mode %}
{% endif %}

{% if _sidebar %}
  {% set _css_class = _css_class ~ ' ' ~ 'ecl-accordion--sidebar' %}
{% endif %}

{% if extra_classes is defined and extra_classes is not empty %}
  {% set _css_class = _css_class ~ ' ' ~ extra_classes %}
{% endif %}

{% if extra_attributes is defined and extra_attributes is not empty and extra_attributes is iterable %}
  {% for attr in extra_attributes %}
    {% if attr.value is defined %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') ~ '="' ~ attr.value|e('html_attr') ~ '"' %}
    {% else %}
      {% set _extra_attributes = _extra_attributes ~ ' ' ~ attr.name|e('html_attr') %}
    {% endif %}
  {% endfor %}
{% endif %}

{# Print the result #}

<div
  class="{{ _css_class }}"
  data-ecl-auto-init="Accordion"
  {{ _extra_attributes|raw }}
>
  {% if _items is not empty %}
    {% for _item in _items %}
      {% set _item_class = 'ecl-accordion__item' %}
      {% if loop.first %}
        {% set _item_class = _item_class ~ ' is-first'  %}
      {% elseif loop.last %}
        {% set _item_class = _item_class ~ ' is-last' %}
      {% endif %}

      <details
        class="{{ _item_class }}"
        {% if _name is not empty %}
          name="{{ _name }}"
        {% endif %}
        {%- if _sidebar -%}
          data-desktop-open
        {% endif %}
        >
        {% set _toggle_class = 'ecl-accordion__toggle' %}
        {% if _item.toggle.extra_classes is defined and _item.toggle.extra_classes is not empty %}
          {% set _toggle_class = _toggle_class ~ ' ' ~ _item.toggle.extra_classes %}
        {% endif %}
        <summary class="{{ _toggle_class }}">
          {{- _item.toggle.label -}}

          {% for icon in _icons %}
            {% include '@ecl/icon/icon.html.twig' with {
              icon: icon|merge({
                size: icon.size|default('s'),
              }),
              extra_classes: 'ecl-accordion__toggle-icon' ~ icon.extra_classes|default(''),
            } only %}
          {% endfor %}
        </summary>
        <div class="ecl-accordion__content">
          {{- _item.content|default('') -}}
        </div>
      </details>

    {% endfor %}
  {% endif %}
</div>

{% endapply %}
